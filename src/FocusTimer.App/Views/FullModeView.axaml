<UserControl xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:converters="using:FocusTimer.App.Converters"
    xmlns:materialIcons="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
    xmlns:vm="using:FocusTimer.App.ViewModels"
    x:DataType="vm:TimerWidgetViewModel"
    x:Class="FocusTimer.App.Views.FullModeView">
    <UserControl.Resources>
        <converters:PlayPauseConverter x:Key="PlayPauseConverter" />
        <converters:BooleanNegationConverter x:Key="BooleanNegationConverter" />
        <converters:BooleanToAngleConverter x:Key="BooleanToAngleConverter" />
    </UserControl.Resources>

    <Grid x:Name="WidgetContentRoot"
        RowDefinitions="Auto,Auto"
        ColumnDefinitions="Auto"
        VerticalAlignment="Center"
        HorizontalAlignment="Center">
        <!-- Row 0: main controls -->
        <Grid Grid.Row="0"
            ColumnDefinitions="Auto,Auto,Auto,Auto,Auto"
            VerticalAlignment="Center">
            <!-- Timer -->
            <Grid x:Name="ClockLayer"
                Grid.Column="0"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                Opacity="{Binding EffectiveClockOpacity}">
                <TextBlock Text="{Binding ElapsedFormatted}"
                    Classes="timer-text"
                    FontSize="{Binding MainTimerFontSize}"
                    Width="{Binding MainTimerTextWidth}"
                    TextAlignment="Center"
                    VerticalAlignment="Center" />
            </Grid>

            <Grid x:Name="ControlsLayer"
                Grid.Column="1"
                Grid.ColumnSpan="4"
                ColumnDefinitions="Auto,Auto,Auto,Auto"
                Opacity="{Binding EffectiveControlsOpacity}"
                IsHitTestVisible="{Binding AreControlsInteractable}">
                <!-- Play/Pause Button -->
                <Button Grid.Column="0"
                Command="{Binding ToggleCommand}"
                Classes="icon-button"
                ToolTip.Tip="Start/Pause"
                Width="{Binding ButtonSize}"
                Height="{Binding ButtonSize}">
                    <materialIcons:MaterialIcon
                    Kind="{Binding IsRunning, Converter={StaticResource PlayPauseConverter}}"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    Width="{Binding IconSize}"
                    Height="{Binding IconSize}" />
                </Button>

                <!-- Reset Button -->
                <Button Grid.Column="1"
                Command="{Binding ResetCommand}"
                Classes="icon-button"
                ToolTip.Tip="Reset"
                Width="{Binding ButtonSize}"
                Height="{Binding ButtonSize}">
                    <materialIcons:MaterialIcon Kind="Refresh"
                    Foreground="{DynamicResource ButtonNormalBrush}"
                    Width="{Binding IconSize}"
                    Height="{Binding IconSize}" />
                </Button>

                <!-- Project Input Toggle Button -->
                <Button Grid.Column="2"
                Command="{Binding ToggleProjectInputCommand}"
                Classes="icon-button"
                ToolTip.Tip="Project Tag"
                Width="{Binding ButtonSize}"
                Height="{Binding ButtonSize}">
                    <materialIcons:MaterialIcon Kind="ChevronDown"
                    Foreground="{DynamicResource ButtonNormalBrush}"
                    Width="{Binding IconSize}"
                    Height="{Binding IconSize}">
                        <materialIcons:MaterialIcon.RenderTransform>
                            <RotateTransform
                            Angle="{Binding IsProjectInputVisible, Converter={StaticResource BooleanToAngleConverter}}" />
                        </materialIcons:MaterialIcon.RenderTransform>
                    </materialIcons:MaterialIcon>
                </Button>

                <!-- Compact Mode Toggle Button -->
                <Button Grid.Column="3"
                Command="{Binding ToggleCompactModeCommand}"
                Classes="icon-button"
                ToolTip.Tip="Toggle Compact Mode"
                Width="{Binding ButtonSize}"
                Height="{Binding ButtonSize}">
                    <materialIcons:MaterialIcon Kind="Menu"
                    Foreground="{DynamicResource ButtonNormalBrush}"
                    Width="{Binding IconSize}"
                    Height="{Binding IconSize}" />
                </Button>
            </Grid>
        </Grid>

        <!-- Row 1: project label & box -->
        <Grid Grid.Row="1"
            ColumnDefinitions="Auto,*,Auto"
            Margin="0,6,0,0"
            Opacity="{Binding EffectiveControlsOpacity}"
            IsHitTestVisible="{Binding AreControlsInteractable}"
            IsVisible="{Binding IsProjectInputVisible}">
            <TextBlock Grid.Column="0"
                Text="Project:"
                FontSize="{Binding ProjectFontSize}"
                Foreground="{DynamicResource SecondaryTextBrush}"
                VerticalAlignment="Center" />
            <TextBox Grid.Column="1"
                Classes="project-tag"
                Text="{Binding ProjectTag}"
                Watermark="optional" />
        </Grid>
    </Grid>
</UserControl>
