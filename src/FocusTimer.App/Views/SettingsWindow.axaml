<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:FocusTimer.App.ViewModels"
        mc:Ignorable="d"
        x:Class="FocusTimer.App.Views.SettingsWindow"
        x:DataType="vm:SettingsWindowViewModel"
        Title="FocusTimer – Settings"
        Width="640" Height="540"
        MinWidth="500" MinHeight="400"
        WindowStartupLocation="CenterOwner"
        CanResize="True"
        Background="{DynamicResource SettingsBackgroundBrush}"
        Foreground="{DynamicResource PrimaryTextBrush}">

    <Design.DataContext>
        <vm:SettingsWindowViewModel />
    </Design.DataContext>

    <!-- Use our theme styles for section headers and labels -->
    <Window.Styles>
        <Style Selector="TextBlock.SectionHeader">
            <Setter Property="FontSize" Value="18" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,8" />
            <Setter Property="Foreground" Value="{DynamicResource SettingsSectionHeaderBrush}" />
        </Style>
        <Style Selector="TextBlock.SettingLabel">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Foreground" Value="{DynamicResource SettingsLabelTextBrush}" />
        </Style>
        <Style Selector="TextBlock.VersionInfoText">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="*,Auto" Margin="20">
        <!-- Settings Content -->
        <TabControl Grid.Row="0">
            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer Classes="settings-scroll">
                    <StackPanel Spacing="15">
                        <TextBlock Classes="SectionHeader" Text="Startup" />

                        <CheckBox IsChecked="{Binding Settings.AutoStartOnLogin}" Content="Start with Windows" />

                        <CheckBox IsChecked="{Binding Settings.StartMinimized}" Content="Start minimized to tray" />

                        <TextBlock Classes="SectionHeader" Text="Window" />

                        <CheckBox IsChecked="{Binding Settings.AlwaysOnTop}" Content="Keep widget always on top" />

                        <TextBlock Classes="SectionHeader" Text="Break Reminders" />

                        <CheckBox IsChecked="{Binding Settings.BreakRemindersEnabled}" Content="Enable break reminders" />

                        <CheckBox IsChecked="{Binding Settings.RequireBreakReminderAcknowledgement}"
                                  Content="Require acknowledgement before break reminders disappear"
                                  IsEnabled="{Binding Settings.BreakRemindersEnabled}" />

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto" Margin="0,0,0,0">
                            <TextBlock Grid.Column="0" Classes="SettingLabel" Text="Remind every (minutes):" />
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding Settings.BreakIntervalMinutes}"
                                           Minimum="1"
                                           Maximum="240"
                                           Increment="5"
                                           Width="120"
                                           HorizontalAlignment="Left"
                                           IsEnabled="{Binding Settings.BreakRemindersEnabled}" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Logging Tab -->
            <TabItem Header="Logging">
                <ScrollViewer Classes="settings-scroll">
                    <StackPanel Spacing="15">
                        <TextBlock Classes="SectionHeader" Text="Worklog CSV Location" />

                        <CheckBox IsChecked="{Binding Settings.WorkLoggingEnabled}"
                                  Content="Enable work logging"
                                  ToolTip.Tip="When disabled, session tracking and persistence are paused." />

                        <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
                            <TextBox Grid.Column="0"
                                     Text="{Binding Settings.WorklogDirectory}"
                                     Watermark="Worklog directory path"
                                     IsReadOnly="True" />
                            <Button Grid.Column="1"
                                    Content="Browse…"
                                    Margin="5,0,0,0"
                                    Command="{Binding BrowseWorklogDirectoryCommand}"
                                    CommandParameter="{Binding $parent[Window]}" />
                        </Grid>

                        <TextBlock Classes="SectionHeader" Text="Data Retention" />

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto">
                            <TextBlock Grid.Column="0" Classes="SettingLabel" Text="Keep worklogs for (days):" />
                            <NumericUpDown Grid.Column="1"
                                           Value="{Binding Settings.DataRetentionDays}"
                                           Minimum="1"
                                           Maximum="3650"
                                           Increment="1"
                                           Width="120"
                                           HorizontalAlignment="Left" />
                        </Grid>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Appearance Tab -->
            <TabItem Header="Appearance">
                <ScrollViewer Classes="settings-scroll">
                    <StackPanel Spacing="15">
                        <!-- Theme Presets Section -->
                        <TextBlock Classes="SectionHeader" Text="Theme Presets" />
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                            <ComboBox Grid.Column="0"
                                      SelectedItem="{Binding SelectedThemeName}"
                                      ItemsSource="{Binding AvailableThemes}"
                                      HorizontalAlignment="Stretch" />
                            <Button Grid.Column="1" Content="Import..."
                                    Command="{Binding ImportThemeCommand}"
                                    CommandParameter="{Binding $parent[Window]}"
                                    Width="80" Margin="10,0,0,0" />
                            <Button Grid.Column="2" Content="Export..."
                                    Command="{Binding ExportThemeCommand}"
                                    CommandParameter="{Binding $parent[Window]}"
                                    Width="80" Margin="10,0,0,0" />
                            <Button Grid.Column="3" Content="Reset"
                                    Command="{Binding ResetThemeCommand}"
                                    Width="80" Margin="10,0,0,0" />
                        </Grid>

                        <TextBlock Classes="SectionHeader" Text="Color Palette" />

                        <Grid ColumnDefinitions="*,12,*">
                            <Expander Grid.Column="0" Header="Timer Widget" IsExpanded="True" Classes="settings-accordion">
                                <Grid ColumnDefinitions="126,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,8,0,0">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="SettingLabel" Text="Background:" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Settings.Theme.WindowBackground}" Watermark="#1E1E1E" Margin="0,0,8,0" />
                                    <Button Grid.Row="0" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.WindowBackground}" Tag="WindowBackground" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" />

                                    <!-- Border color removed temporarily -->

                                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="SettingLabel" Text="Timer Text:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.Theme.TimerText}" Watermark="#FFFFFF" Margin="0,6,8,0" />
                                    <Button Grid.Row="2" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.TimerText}" Tag="TimerText" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="SettingLabel" Text="Timer Background:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Settings.Theme.TimerBackground}" Watermark="#00000000" Margin="0,6,8,0" />
                                    <Button Grid.Row="3" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.TimerBackground}" Tag="TimerBackground" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="SettingLabel" Text="Button Normal:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Settings.Theme.ButtonNormal}" Watermark="#4CDEFFBD" Margin="0,6,8,0" />
                                    <Button Grid.Row="4" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.ButtonNormal}" Tag="ButtonNormal" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="5" Grid.Column="0" Classes="SettingLabel" Text="Button Hover:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Settings.Theme.ButtonHover}" Watermark="#5DEFFCE7" Margin="0,6,8,0" />
                                    <Button Grid.Row="5" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.ButtonHover}" Tag="ButtonHover" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="6" Grid.Column="0" Classes="SettingLabel" Text="Button Pressed:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Settings.Theme.ButtonPressed}" Watermark="#3BBD99AC" Margin="0,6,8,0" />
                                    <Button Grid.Row="6" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.ButtonPressed}" Tag="ButtonPressed" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="7" Grid.Column="0" Classes="SettingLabel" Text="Button Disabled:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Settings.Theme.ButtonDisabled}" Watermark="#40FFFFFF" Margin="0,6,8,0" />
                                    <Button Grid.Row="7" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.ButtonDisabled}" Tag="ButtonDisabled" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />
                                </Grid>
                            </Expander>

                            <Expander Grid.Column="2" Header="Dialogs &amp; Notifications" IsExpanded="True" Classes="settings-accordion">
                                <Grid ColumnDefinitions="126,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" Margin="0,8,0,0">
                                    <TextBlock Grid.Row="0" Grid.Column="0" Classes="SettingLabel" Text="Background:" />
                                    <TextBox Grid.Row="0" Grid.Column="1" Text="{Binding Settings.Theme.SettingsBackground}" Watermark="#2D2D30" Margin="0,0,8,0" />
                                    <Button Grid.Row="0" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.SettingsBackground}" Tag="SettingsBackground" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" />

                                    <TextBlock Grid.Row="1" Grid.Column="0" Classes="SettingLabel" Text="Primary Text:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding Settings.Theme.PrimaryText}" Watermark="#F5F5F5" Margin="0,6,8,0" />
                                    <Button Grid.Row="1" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.PrimaryText}" Tag="PrimaryText" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="2" Grid.Column="0" Classes="SettingLabel" Text="Secondary Text:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding Settings.Theme.SecondaryText}" Watermark="#CCCCCC" Margin="0,6,8,0" />
                                    <Button Grid.Row="2" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.SecondaryText}" Tag="SecondaryText" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="3" Grid.Column="0" Classes="SettingLabel" Text="Header Text:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="3" Grid.Column="1" Text="{Binding Settings.Theme.SettingsSectionHeader}" Watermark="#F5F5F5" Margin="0,6,8,0" />
                                    <Button Grid.Row="3" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.SettingsSectionHeader}" Tag="SettingsSectionHeader" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="4" Grid.Column="0" Classes="SettingLabel" Text="Body Text:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="4" Grid.Column="1" Text="{Binding Settings.Theme.SettingsLabelText}" Watermark="#CCCCCC" Margin="0,6,8,0" />
                                    <Button Grid.Row="4" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.SettingsLabelText}" Tag="SettingsLabelText" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="5" Grid.Column="0" Classes="SettingLabel" Text="Accent:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="5" Grid.Column="1" Text="{Binding Settings.Theme.AccentPrimary}" Watermark="#0078D7" Margin="0,6,8,0" />
                                    <Button Grid.Row="5" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.AccentPrimary}" Tag="AccentPrimary" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="6" Grid.Column="0" Classes="SettingLabel" Text="Success:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="6" Grid.Column="1" Text="{Binding Settings.Theme.SuccessColor}" Watermark="#4CAF50" Margin="0,6,8,0" />
                                    <Button Grid.Row="6" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.SuccessColor}" Tag="SuccessColor" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="7" Grid.Column="0" Classes="SettingLabel" Text="Warning:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="7" Grid.Column="1" Text="{Binding Settings.Theme.WarningColor}" Watermark="#FFA726" Margin="0,6,8,0" />
                                    <Button Grid.Row="7" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.WarningColor}" Tag="WarningColor" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />

                                    <TextBlock Grid.Row="8" Grid.Column="0" Classes="SettingLabel" Text="Danger:" Margin="0,6,0,0" />
                                    <TextBox Grid.Row="8" Grid.Column="1" Text="{Binding Settings.Theme.DangerColor}" Watermark="#D9534F" Margin="0,6,8,0" />
                                    <Button Grid.Row="8" Grid.Column="2" Classes="color-swatch" Background="{Binding Settings.Theme.DangerColor}" Tag="DangerColor" Click="OnColorPreviewClicked" ToolTip.Tip="Open color picker" Margin="0,6,0,0" />
                                </Grid>
                            </Expander>
                        </Grid>

                        <!-- Opacity Controls Section -->

                        <TextBlock Classes="SectionHeader" Text="Opacity Controls" />
                        <Grid ColumnDefinitions="140,*,Auto" RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto">
                            <!-- Widget Base opacity slider removed temporarily -->

                            <TextBlock Grid.Row="1" Grid.Column="0" Classes="SettingLabel" Text="Background:" />
                            <Slider Grid.Row="1" Grid.Column="1"
                                    Classes="minimal-slider"
                                Value="{Binding BackgroundOpacityPercent}"
                                Minimum="0" Maximum="100"
                                TickFrequency="1"
                                    IsSnapToTickEnabled="True" />
                            <TextBlock Grid.Row="1" Grid.Column="2"
                                   Text="{Binding BackgroundOpacityPercent, StringFormat='{}{0:F0}%'}"
                                       Width="50"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0" />

                            <TextBlock Grid.Row="2" Grid.Column="0" Classes="SettingLabel" Text="Clock:" Margin="0,4,0,0" />
                            <Slider Grid.Row="2" Grid.Column="1"
                                    Classes="minimal-slider"
                                    Value="{Binding ClockOpacityPercent}"
                                    Minimum="0" Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,4,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="2"
                                       Text="{Binding ClockOpacityPercent, StringFormat='{}{0:F0}%'}"
                                       Width="50"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="10,4,0,0" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Classes="SettingLabel" Text="Buttons:" Margin="0,4,0,0" />
                            <Slider Grid.Row="3" Grid.Column="1"
                                    Classes="minimal-slider"
                                    Value="{Binding ButtonsOpacityPercent}"
                                    Minimum="0" Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,4,0,0" />
                            <TextBlock Grid.Row="3" Grid.Column="2"
                                       Text="{Binding ButtonsOpacityPercent, StringFormat='{}{0:F0}%'}"
                                       Width="50"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="10,4,0,0" />

                            <TextBlock Grid.Row="4" Grid.Column="0" Classes="SettingLabel" Text="Overall Fade:" Margin="0,4,0,0" />
                            <Slider Grid.Row="4" Grid.Column="1"
                                    Classes="minimal-slider"
                                    Value="{Binding OverallFadePercent}"
                                    Minimum="0" Maximum="100"
                                    TickFrequency="1"
                                    IsSnapToTickEnabled="True"
                                    Margin="0,4,0,0" />
                            <TextBlock Grid.Row="4" Grid.Column="2"
                                       Text="{Binding OverallFadePercent, StringFormat='{}{0:F0}%'}"
                                       Width="50"
                                       TextAlignment="Right"
                                       VerticalAlignment="Center"
                                       Margin="10,4,0,0" />

                            <!-- Border opacity slider removed temporarily -->
                        </Grid>

                        <Border CornerRadius="10"
                                BorderThickness="1"
                                BorderBrush="#30FFFFFF"
                                Background="#12000000"
                                Padding="10"
                                Margin="0,6,0,0">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Opacity Diagnostics"
                                           FontWeight="SemiBold"
                                           Foreground="{DynamicResource SettingsSectionHeaderBrush}" />
                                <TextBlock Text="{Binding TransparencyDiagnostics}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding AcrylicDiagnostics}"
                                           TextWrapping="Wrap"
                                           Foreground="{DynamicResource SecondaryTextBrush}" />
                                <TextBlock Text="{Binding OpacityDiagnosticsSummary}"
                                           Foreground="{DynamicResource SettingsLabelTextBrush}" />
                            </StackPanel>
                        </Border>

<!-- Widget Options Section -->
                        <TextBlock Classes="SectionHeader" Text="Widget Options" />
                        <Grid ColumnDefinitions="140,*,Auto" RowDefinitions="Auto,Auto">

                            <TextBlock Grid.Row="1" Grid.Column="0" Classes="SettingLabel" Text="Scale:" Margin="0,8,0,0" />
                            <Slider Grid.Row="1" Grid.Column="1" Classes="minimal-slider" Value="{Binding Settings.WidgetScale}" Minimum="0.5" Maximum="3.0" TickFrequency="0.1" IsSnapToTickEnabled="True" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="2" Text="{Binding Settings.WidgetScale, StringFormat='{}{0:F1}×'}" Width="50" TextAlignment="Right" VerticalAlignment="Center" Margin="10,8,0,0" />
                        </Grid>

                        <CheckBox IsChecked="{Binding Settings.UseCompactMode}" Content="Use compact mode" ToolTip.Tip="Switches the timer widget into a minimal mode" />
                        <TextBlock TextWrapping="Wrap" FontSize="12" Foreground="{DynamicResource SettingsLabelTextBrush}"
                                   Text="Note: Color changes apply immediately. Use hex format (#RRGGBBAA or #RRGGBB). Import/export .fttheme files to share themes." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <TabItem Header="About">
                <ScrollViewer Classes="settings-scroll">
                    <StackPanel Spacing="12">
                        <TextBlock Classes="SectionHeader" Text="Application" />

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto" Margin="0,0,0,8">
                            <TextBlock Grid.Row="0" Grid.Column="0" Classes="SettingLabel" Text="Version:" />
                            <TextBlock Grid.Row="0" Grid.Column="1"
                                       Classes="VersionInfoText"
                                       HorizontalAlignment="Left"
                                       Text="{Binding AppVersion}"
                                       PointerPressed="OnVersionInfoPressed"
                                       ToolTip.Tip="Click 7 times to unlock developer mode" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Classes="SettingLabel" Text="Repository:" Margin="0,8,0,0" />
                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                                <TextBlock VerticalAlignment="Center" Text="{Binding RepositoryUrl}" TextWrapping="Wrap" />
                                <Button Content="Open" Width="70" Command="{Binding OpenRepositoryCommand}" />
                            </StackPanel>

                            <TextBlock Grid.Row="2" Grid.Column="0" Classes="SettingLabel" Text="Author:" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding AppAuthor}" Margin="0,8,0,0" TextWrapping="Wrap" />

                            <TextBlock Grid.Row="3" Grid.Column="0" Classes="SettingLabel" Text="Info:" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding AppInformation}" Margin="0,8,0,0" TextWrapping="Wrap" />
                        </Grid>

                        <Expander Header="Changelog" IsExpanded="False" Classes="settings-accordion">
                            <Border Padding="0,8,0,0">
                                <ScrollViewer MaxHeight="220">
                                    <TextBlock Text="{Binding ChangelogContent}" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" />
                                </ScrollViewer>
                            </Border>
                        </Expander>

                        <Expander Header="Developer Options"
                                  Classes="settings-accordion"
                                  IsVisible="{Binding IsDeveloperModeVisible}">
                            <StackPanel Spacing="10" Margin="0,8,0,0">
                                <Grid ColumnDefinitions="120,*" RowDefinitions="Auto">
                                    <TextBlock Grid.Column="0" Classes="SettingLabel" Text="Log Level:" />
                                    <ComboBox Grid.Column="1"
                                              SelectedItem="{Binding SelectedDeveloperLogLevel}"
                                              ItemsSource="{Binding AvailableDeveloperLogLevels}"
                                              HorizontalAlignment="Left"
                                              Width="180" />
                                </Grid>

                                <TextBlock TextWrapping="Wrap"
                                           Foreground="{DynamicResource SettingsLabelTextBrush}"
                                           FontSize="11"
                                           Text="Developer options are experimental and will grow over time." />
                            </StackPanel>
                        </Expander>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Hotkeys Tab -->
            <TabItem Header="Hotkeys">
                <ScrollViewer Classes="settings-scroll">
                    <StackPanel Spacing="15">
                        <TextBlock Classes="SectionHeader" Text="Global Hotkeys" />
                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SettingsLabelTextBrush}"
                                   Margin="0,0,0,10"
                                   Text="Note: Hotkeys work system‑wide even when the app is not focused. Windows only." />

                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto">
                            <TextBlock Grid.Row="0" Grid.Column="0" Classes="SettingLabel" Text="Show/Hide Widget:" />
                            <TextBox Grid.Row="0" Grid.Column="1"
                                     Text="{Binding Settings.HotkeyShowHide}"
                                     Watermark="e.g. Ctrl+Alt+T"
                                     Width="200"
                                     HorizontalAlignment="Left"
                                     IsReadOnly="True"
                                     ToolTip.Tip="Default: Ctrl+Alt+T (editable hotkeys coming soon)" />

                            <TextBlock Grid.Row="1" Grid.Column="0" Classes="SettingLabel" Text="Toggle Timer:" Margin="0,10,0,0" />
                            <TextBox Grid.Row="1" Grid.Column="1"
                                     Text="{Binding Settings.HotkeyToggleTimer}"
                                     Watermark="e.g. Ctrl+Alt+P"
                                     Width="200"
                                     HorizontalAlignment="Left"
                                     IsReadOnly="True"
                                     ToolTip.Tip="Default: Ctrl+Alt+P (editable hotkeys coming soon)"
                                     Margin="0,10,0,0" />
                        </Grid>

                        <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SettingsLabelTextBrush}" FontSize="11" Margin="0,10,0,0"
                                   Text="Tip: Hotkeys are registered when the app starts. Changes require restart." />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Button Panel -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,15,0,0">
            <Button Content="OK" Width="80" Command="{Binding OkCommand}" Click="OnOkClicked" />
            <Button Content="Apply" Width="80" Command="{Binding ApplyCommand}" />
            <Button Content="Cancel" Width="80" Command="{Binding CancelCommand}" CommandParameter="{Binding $parent[Window]}" />
        </StackPanel>
    </Grid>
</Window>
