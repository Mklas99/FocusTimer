#!/bin/bash
# Pre-commit hook for FocusTimer
# Runs code analysis before allowing commits
# Install: cp .githooks/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit

set -e

PROJECT_ROOT="$(git rev-parse --show-toplevel)"
cd "$PROJECT_ROOT"

echo "🔍 Running pre-commit checks..."
echo ""

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Check if staged C# files exist
STAGED_CS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep '\.cs$' || true)

if [ -z "$STAGED_CS_FILES" ]; then
    echo -e "${GREEN}✓ No C# files to check${NC}"
    exit 0
fi

echo -e "${YELLOW}Checking staged files:${NC}"
echo "$STAGED_CS_FILES"
echo ""

# Build the project to check for compilation errors
echo -e "${YELLOW}→ Building project...${NC}"
if ! dotnet build FocusTimer.sln -c Release -q 2>&1 | grep -E "(error|Error)" > /dev/null; then
    echo -e "${GREEN}✓ Build passed${NC}"
else
    echo -e "${RED}✗ Build failed! Fix errors before committing.${NC}"
    exit 1
fi

echo ""

# Check for code analysis issues (warnings as errors)
echo -e "${YELLOW}→ Running code analysis...${NC}"
if dotnet build FocusTimer.sln -c Release -p:TreatWarningsAsErrors=true -p:EnforceCodeStyleInBuild=true -q 2>/dev/null; then
    echo -e "${GREEN}✓ Code analysis passed${NC}"
else
    echo -e "${RED}✗ Code analysis issues found!${NC}"
    echo -e "${YELLOW}Run: dotnet build FocusTimer.sln -c Release -p:EnforceCodeStyleInBuild=true${NC}"
    echo -e "${YELLOW}to see detailed issues.${NC}"
    exit 1
fi

echo ""
echo -e "${GREEN}✓ All pre-commit checks passed!${NC}"
exit 0
